# fsi-compliance-agent — environment configuration
# Copy to .env and fill in. Never commit .env.

# --- Provider selection (both supported; OpenAI is the default) ---
# LLM_PROVIDER: openai | anthropic
# EMBED_PROVIDER: openai | voyage
LLM_PROVIDER=openai
EMBED_PROVIDER=openai

# --- OpenAI (default provider) ---
OPENAI_API_KEY=sk-...
OPENAI_TRIAGE_MODEL=gpt-4.1-mini
OPENAI_DETERMINATION_MODEL=gpt-4.1
OPENAI_JUDGE_MODEL=gpt-4.1
OPENAI_EMBED_MODEL=text-embedding-3-large

# --- Anthropic (alternative provider; set LLM_PROVIDER=anthropic to use) ---
ANTHROPIC_API_KEY=sk-ant-...
HAIKU_MODEL=claude-haiku-4-5-20250929
SONNET_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-opus-4-7

# --- Voyage embeddings (set EMBED_PROVIDER=voyage to use) ---
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3-large

# Embedding dimension is shared across providers (both support it).
EMBED_DIM=256

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=compliance_rulebook

# --- Abstention / conformal calibration ---
# alpha=0.05 is stricter than a typical RAG system (0.10): compliance tolerates
# fewer wrong auto-decisions. abstention_threshold is overwritten by `make calibrate`.
ABSTENTION_ALPHA=0.05
ABSTENTION_THRESHOLD=0.60

# --- Slack human-in-the-loop approval gate ---
# Leave SLACK_BOT_TOKEN empty to run in dry-run mode (no live Slack calls).
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL=#compliance-approvals
APPROVAL_TIMEOUT_S=3600

# --- Audit log location ---
AUDIT_LOG_PATH=audit/audit_log.jsonl
